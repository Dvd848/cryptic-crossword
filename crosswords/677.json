  "definitions": {
    "down": {
      "1": "\u05d9\u05e9 \u05de\u05d9\u05df \u05d1\u05e2\u05d9\u05d4 \u05e2\u05dd \u05d4\u05e2\u05d5\u05e3 \u05d4\u05d6\u05d4 (5)",
      "2": "\u05e9\u05d5\u05d1 \u05d7\u05e1\u05e8 \u05de\u05e9\u05d4\u05d5 \u05d1\u05d2\u05d2 (3)",
      "3": "\u05e2\u05d5\u05e3 \u05d1\u05d3\u05e8\u05da \u05dc\u05d0\u05d9\u05d8\u05dc\u05d9\u05d4 (5)",
      "4": "\u05ea\u05e9\u05d7\u05e8\u05e8\u05d5 \u05de\u05e4\u05dc\u05e6\u05ea, \u05d6\u05d4 \u05d8\u05d9\u05e4\u05d5\u05dc\u05d9 (7)",
      "5": "\u05d7\u05d1\u05e8 \u05de\u05e0\u05d2\u05d9\u05e0\u05d5\u05ea \u05dc\u05d0\u05dc\u05d5 \u05e9\u05de\u05ea\u05e4\u05dc\u05dc\u05d9\u05dd \u05de\u05d7\u05d5\u05e5 \u05dc\u05d1\u05ea\u05d9\u05dd (8)",
      "6": "\u05e8\u05d0\u05d4/\u05d9 25 \u05de\u05d0\u05d5\u05d6\u05df",
      "7": "\u05db\u05d1\u05e8 \u05e0\u05de\u05d0\u05e1 \u05dc\u05d9, \u05d0\u05d8\u05de\u05d9\u05df \u05d0\u05ea \u05ea\u05d5\u05e6\u05d0\u05ea \u05d4\u05d1\u05d3\u05d9\u05e7\u05d4 (8)",
      "11": "\u05d4\u05e7\u05e4\u05dc \u05e9\u05d1\u05de\u05e6\u05d1 \u05d2\u05e8\u05d5\u05e2 \u05e2\u05d5\u05dc\u05d4 \u05dc\u05e7\u05d9\u05d1\u05d5\u05e5 (3, 4)",
      "13": "\u05d1\u05e0\u05d9 \u05e6\u05e2\u05e7: \u05d6\u05d4 \u05e1\u05d5\u05d2 \u05e9\u05dc \u05d9\u05e9\u05d5\u05d1 (3, 4)",
      "15": "\u05dc\u05d0 \u05d0\u05e4\u05e1\u05d9\u05e7 \u05dc\u05e1\u05d5\u05d1\u05d1 \u05d1\u05d8\u05dc\u05d5\u05d5\u05d9\u05d6\u05d9\u05d4 (4, 4)",
      "16": "\u05de\u05d4\u05d3\u05d1\u05e8\u05e0\u05d9\u05ea \u05d4\u05ea\u05e7\u05d1\u05dc\u05d5 \u05d2\u05e0\u05d9\u05dd \u05d9\u05e4\u05d9\u05dd (3, 5)",
      "17": "\u05d2'\u05d5 \u05e9\u05d5\u05d1 \u05e9\u05e4\u05d8 \u05d0\u05d5\u05ea\u05dd \u05d1\u05ea\u05d5\u05da \u05e8\u05db\u05d1 \u05e6\u05d1\u05d0\u05d9 (7)",
      "19": "\u05db\u05d5\u05dc\u05dd \u05d7\u05de\u05d9\u05dd \u05e2\u05dc \u05d4\u05d1\u05d3\u05d9\u05e7\u05d5\u05ea \u05d4\u05d0\u05dc\u05d4 (5)",
      "20": "\u05d6\u05d4 \u05dc\u05d0 \u05d0\u05de\u05d9\u05ea\u05d9 \u05e9\u05d4\u05d3\u05d5\u05e7\u05d8\u05d5\u05e8 \u05e0\u05e8\u05d0\u05d4 \u05d8\u05d5\u05d1 (5)",
      "22": "\u05d9\u05e1\u05d5\u05d3 \u05d4\u05de\u05e2\u05dc\u05d4 \u05db\u05e9\u05d0\u05e0\u05d7\u05e0\u05d5 \u05e0\u05de\u05d4\u05e8 (4)",
      "24": "\u05d0\u05de\u05e0\u05dd \u05de\u05d5\u05d1\u05d7\u05e8 \u05d0\u05d1\u05dc \u05d0\u05e4\u05e1, \u05d0\u05d9\u05df \u05d1\u05d5 \u05db\u05dc\u05d5\u05dd (3) (\u05d7)"
    },
    "across": {
      "1": "\u05e9\u05d5\u05d1 \u05d7\u05ea\u05db\u05ea \u05d0\u05ea \u05e8\u05d0\u05e9 \u05d4\u05db\u05d5\u05d7 \u05d1\u05d7\u05d8\u05d0? \u05db\u05d1\u05e8 \u05d4\u05d9\u05d4 \u05dc\u05e0\u05d5 \u05d2\u05e8\u05d5\u05e2 \u05d9\u05d5\u05ea\u05e8 (5, 2, 4)",
      "8": "\u05d6\u05d4 \u05d9\u05e7\u05e8\u05d4 \u05e9\u05d5\u05d1, \u05d0\u05d1\u05dc \u05dc\u05d0 \u05d1\u05d0\u05d5\u05e4\u05df \u05e7\u05d1\u05d5\u05e2 (4)",
      "9": "\u05d3\u05d5\u05e7\u05d8\u05d5\u05e8 \u05dc\u05d7\u05dd? \u05e8\u05d5\u05d0\u05d9\u05dd \u05e9\u05d6\u05d4 \u05de\u05de\u05e9 \u05de\u05ea\u05d5\u05e7 (4, 5) (\u05de)",
      "10": "\u05db\u05ea\u05d1\u05e0\u05d5 \u05d1\u05e6\u05e4\u05d5\u05df \u05d4\u05d7\u05dc\u05d9\u05e3 \u05d0\u05ea \u05d4\u05d1\u05df \u05d5\u05e7\u05d9\u05d1\u05dc \u05d7\u05d9\u05d4 \u05e0\u05d3\u05d9\u05e8\u05d4 (3, 3)",
      "12": "\u05d1\u05d0\u05d9\u05d6\u05d4 \u05e8\u05db\u05d1 \u05d4\u05d5\u05d0 \u05de\u05e1\u05ea\u05d5\u05d1\u05d1 \u05d1\u05d9\u05de\u05d9\u05dd \u05d0\u05dc\u05d4? (5)",
      "14": "\u05d4\u05d3\u05d5\u05e7\u05d8\u05d5\u05e8 \u05d0\u05db\u05dc \u05d3\u05d2 \u05d1\u05d0\u05d6\u05d5\u05e8 \u05e6\u05d7\u05d9\u05d7? \u05dc\u05d4\u05d9\u05e4\u05da! (6)",
      "15": "\u05e9\u05e8\u05d9\u05d3\u05d9 \u05e9\u05e8\u05e4\u05ea \u05e9\u05d8\u05e8\u05df \u05d4\u05d9\u05d5 \u05e7\u05d1\u05d5\u05e2\u05d9\u05dd \u05de\u05e8\u05d0\u05e9 (1, 6)",
      "17": "\u05db\u05d6\u05d4 \u05e8\u05db\u05d1, \u05d6\u05d4 \u05de\u05d4 \u05e9\u05d4\u05d9\u05d0 \u05ea\u05e7\u05d1\u05dc \u05de\u05d0\u05d9\u05e9 \u05d7\u05d1\u05e8\u05d4 \u05e7\u05d3\u05d9\u05e9\u05d0 (7)",
      "18": "\u05d4\u05de\u05e7\u05d5\u05dd \u05d1\u05d5 \u05d0\u05e0\u05d7\u05e0\u05d5 \u05de\u05ea\u05d1\u05d8\u05dc\u05d9\u05dd, \u05d5\u05db\u05dc \u05d4\u05e9\u05d0\u05e8 (6)",
      "19": "\u05ea\u05d1\u05d5\u05d0 \u05d1\u05d7\u05de\u05e9, \u05d9\u05d4\u05d9\u05d4 \u05de\u05e9\u05d4\u05d5 \u05d8\u05e2\u05d9\u05dd (5)",
      "21": "\u05d4\u05e9\u05d7\u05e7\u05df \u05de\u05e8\u05d9\u05dd \u05d0\u05e0\u05d8\u05d9\u05e9\u05de\u05d9 \u05de\u05e6\u05d3 \u05e9\u05de\u05d0\u05dc (3, 3) (\u05de)",
      "23": "\u05e0\u05e2\u05d1\u05d9\u05e8 \u05d0\u05ea \u05d4\u05d9\u05d7\u05d9\u05d3\u05d4 \u05d4\u05e6\u05d1\u05d0\u05d9\u05ea \u05d1\u05d7\u05d6\u05e8\u05d4 \u05dc\u05e1\u05d5\u05e4\u05e8 (3, 6)",
      "25": "\u05e2\u05dd 6 \u05de\u05d0\u05d5\u05e0\u05da. \u05d4\u05dc\u05dc \u05d0\u05de\u05e8 \u05d0\u05ea \u05d3\u05e2\u05ea\u05d5 \u05e4\u05e2\u05dd \u05e2\u05dc \u05d4\u05e2\u05d9\u05ea\u05d5\u05df (4, 4)",
