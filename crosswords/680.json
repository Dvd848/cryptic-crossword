  "definitions": {
    "down": {
      "1": "\u05e2\u05dd 2 \u05de\u05d0\u05d5\u05e0\u05da. \u05dc\u05d4\u05d5\u05e6\u05d9\u05d0 \u05de\u05d4\u05de\u05e7\u05d5\u05dd \u05d0\u05ea \u05d4\u05d0\u05d7\u05e8\u05d0\u05d9 \u05d0\u05d7\u05d4\"\u05e6 (5, 3)",
      "2": "\u05e8\u05d0\u05d4/\u05d9 1 \u05de\u05d0\u05d5\u05e0\u05da",
      "3": "\u05e9\u05d5\u05d1 \u05e0\u05e7\u05d9\u05ea\u05d9 \u05d5\u05d9\u05d4\u05d9\u05d5 \u05dc\u05d5 \u05e6\u05e8\u05d5\u05ea (5)",
      "4": "\u05d6\u05d4 \u05e9\u05de\u05ea\u05db\u05d5\u05e4\u05e3 \u05e8\u05e1\u05e7 \u05d0\u05ea \u05d6\u05d4 \u05e9\u05d6\u05d6 \u05d1\u05e0\u05d2\u05d1 (3, 4)",
      "5": "\u05e9\u05dc\u05d9\u05d8\u05d4 \u05de\u05d5\u05d7\u05dc\u05d8\u05ea \u05d1\u05d7\u05d5\u05de\u05e8, \u05d4\u05d5\u05d2\u05df \u05d5\u05e7\u05e4\u05d4 (3, 5)",
      "6": "\u05d4\u05e0\u05e9\u05d9\u05d0 \u05d7\u05d5\u05d6\u05e8 \u05d1\u05dc\u05d9 \u05e1\u05d5\u05e3 \u05d1\u05e4\u05ea\u05d9\u05d7\u05d4 (4)",
      "7": "\u05e0\u05d5\u05d6\u05dc \u05d5\u05d0\u05d7\u05d3 \u05d4\u05d1\u05e0\u05d9\u05dd \u05d5\u05e2\u05d9\u05e8 \u05d6\u05d4 \u05de\u05d9\u05e9\u05d4\u05d5 \u05de\u05e2\u05d5\u05e8\u05e8 \u05d4\u05e9\u05e8\u05d0\u05d4 (4, 4)",
      "11": "\u05ea\u05e4\u05e8 \u05e7\u05d9\u05d9\u05dd! \u05d4\u05dd \u05d6\u05d6\u05d5 \u05d5\u05d9\u05e7\u05d1\u05dc\u05d5 \u05d0\u05ea \u05d4\u05d3\u05d1\u05e8\u05d9\u05dd (7)",
      "13": "\u05d4\u05e8\u05d9\u05dd \u05e7\u05e8\u05d5\u05d1 \u05d1\u05d7\u05d6\u05e8\u05d4 \u05d1\u05d2\u05dc\u05d9\u05dc (3, 4) (\u05de)",
      "15": "\u05e9\u05d5\u05d1 \u05d4\u05e8\u05d2\u05d4 \u05d0\u05ea \u05d4\u05de\u05e9\u05e2\u05de\u05dd \u05db\u05d9 \u05d4\u05d5\u05d0 \u05d0\u05d7\u05e8\u05d0\u05d9 \u05dc\u05e9\u05dc\u05d5\u05dd \u05d4\u05de\u05dc\u05da (4, 4)",
      "16": "\u05d0\u05d7\u05e8\u05d0\u05d9 \u05ea\u05e7\u05e9\u05d5\u05d1 \u05d5\u05de\u05dc\u05d7\u05d9\u05df? \u05d6\u05d5 \u05d1\u05e2\u05d9\u05d4 \u05e1\u05d1\u05d5\u05db\u05d4 (3, 5)",
      "17": "\u05d0\u05d9\u05df \u05dc\u05d5 \u05d0\u05d5\u05de\u05e5 \u05d1\u05de\u05e7\u05d5\u05de\u05d5\u05ea \u05e9\u05e9\u05d5\u05ea\u05d9\u05dd \u05d1\u05d4\u05dd \u05d0\u05d6 \u05d6\u05d4 \u05de\u05d5\u05e1\u05d9\u05e3 \u05dc\u05d4\u05dd \u05db\u05d7 (7)",
      "19": "\u05d4\u05e8\u05d0\u05e9 \u05e9\u05dc \u05d4\u05e0\u05e9\u05d9\u05d0 \u05d1\u05db\u05dc\u05d0 (5)",
      "20": "\u05e9\u05d5\u05dd \u05de\u05d7\u05d9\u05ea \u05e9\u05dc \u05e4\u05e8\u05d9 (5)",
      "22": "\u05de\u05e1\u05e8\u05d9\u05d7 \u05d7\u05d5\u05d6\u05e8 \u05d0\u05d7\u05e8\u05d9 \u05d4\u05d6\u05e8\u05d9\u05d7\u05d4 (4)",
      "24": "\u05e8\u05d9\u05e7\u05d5\u05d3 \u05de\u05db\u05dc \u05db\u05d9\u05d5\u05d5\u05df (3)"
    },
    "across": {
      "1": "\u05dc\u05e2\u05d1\u05d5\u05d3 \u05e2\u05dc \u05e6\u05d9\u05e0\u05d5\u05e8\u05d5\u05ea \u05d4\u05de\u05e2\u05e8\u05d1 \u05d5\u05dc\u05e1\u05d1\u05da \u05d0\u05ea \u05d4\u05de\u05e6\u05d1 (6, 5)",
      "8": "\u05dc\u05de\u05e2\u05e9\u05d4 \u05d1\u05de\u05d4 \u05e9\u05e6\u05d5\u05de\u05d7 \u05dc\u05d4\u05dd (4)",
      "9": "\u05ea\u05e9\u05d1 \u05e2\u05dc \u05e9\u05e8\u05e7\u05df? \u05d0\u05d9\u05df \u05dc\u05d4 \u05e9\u05d5\u05dd \u05d0\u05de\u05d9\u05e0\u05d5\u05ea (5, 4)",
      "10": "\u05d0\u05d9\u05df \u05d1\u05d4\u05df \u05e1\u05e4\u05e7 \u05d5\u05d8\u05d9\u05e1\u05d5\u05ea (6)",
      "12": "\u05ea\u05d5\u05e1\u05d9\u05e3 \u05e0\u05e7\u05d5\u05d3\u05d4 \u05d1\u05d6\u05de\u05df (5)",
      "14": "\u05de\u05d5\u05e4\u05ea \u05e9\u05dc \u05d1\u05d4\u05de\u05d5\u05ea \u05e9\u05dc\u05d5\u05e7\u05d7\u05d9\u05dd \u05d0\u05d5\u05ea\u05df \u05d1\u05d7\u05e9\u05d1\u05d5\u05df (6)",
      "15": "\u05d7\u05d1\u05e8 \u05e9\u05d9\u05d7\u05d1\u05d5\u05d8 \u05e2\u05dd \u05e8\u05d2\u05dc\u05d5, \u05d6\u05d4 \u05dc\u05d0 \u05d4\u05d3\u05d1\u05e8 \u05d4\u05e2\u05d9\u05e7\u05e8\u05d9 (4, 3)",
      "17": "\u05d0\u05d5\u05dc\u05d9 \u05d1\u05db\u05d5\u05e8\u05d5\u05ea \u05d5\u05de\u05d7\u05dc\u05d4, \u05d4\u05d5\u05d0 \u05d7\u05d5\u05d6\u05e8 \u05d5\u05d1\u05d2\u05d3\u05d5\u05dc! (3, 4)",
      "18": "\u05d9\u05d3 \u05d5\u05e8\u05d2\u05dc \u05d4\u05d7\u05dc\u05d9\u05e3 \u05dc\u05d1\u05d5 \u05d0\u05d6 \u05d9\u05d4\u05d9\u05d4 \u05dc\u05d4\u05dd \u05de\u05e2\u05de\u05d3 (6)",
      "19": "\u05e7\u05e0\u05d9\u05d5\u05df \u05d4\u05d7\u05dc\u05d9\u05e3 \u05d9\u05dc\u05d5 \u05d5\u05e2\u05db\u05e9\u05d9\u05d5 \u05d4\u05d5\u05d0 \u05dc\u05d0 \u05e8\u05d9\u05e7 (5)",
      "21": "\u05dc\u05d0 \u05d4\u05e9\u05d0\u05e8\u05e0\u05d5 \u05de\u05e7\u05d5\u05dd \u05dc\u05e1\u05e4\u05e7: \u05ea\u05df \u05d0\u05ea \u05d4\u05e8\u05db\u05d1! (6)",
      "23": "\u05e6\u05d9\u05d9\u05e8\u05d5 \u05e8\u05d0\u05e9 \u05d7\u05d5\u05d3\u05e9 \u05db\u05e4\u05d5\u05dc \u05d5\u05e9\u05e0\u05d9 \u05d5\u05d4\u05d5\u05d0 \u05e0\u05d9\u05e1\u05d4 \u05dc\u05e7\u05dc\u05d5\u05d8 \u05d0\u05ea \u05d4\u05e1\u05d1\u05d9\u05d1\u05d4 (4, 5) (\u05d7)",
      "25": "\u05d4\u05e0\u05e6\u05d9\u05d7\u05d5 \u05d0\u05ea \u05d4\u05e6\u05d5\u05e8\u05d4 \u05e9\u05dc\u05d5 (4)",
      "26": "\u05d7\u05d6\u05df \u05d7\u05d5\u05d6\u05e8 \u05d0\u05d7\u05e8\u05d9 \u05d0\u05e0\u05d5\u05e0\u05d9\u05de\u05d9 \u05db\u05d3\u05d9 \u05dc\u05ea\u05ea \u05de\u05d4 \u05e9\u05e6\u05e8\u05d9\u05da \u05d1\u05d5\u05d5\u05d3\u05d0\u05d5\u05ea \u05de\u05d5\u05d7\u05dc\u05d8\u05ea (3, 3, 2, 3)"
