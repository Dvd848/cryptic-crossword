  "definitions": {
    "down": {
      "1": "\u05e4\u05e7\u05d5\u05d3\u05d4 \u05d9\u05e9\u05d9\u05e8\u05d4 \u05dc\u05d9\u05e8\u05d5\u05ea \u05db\u05e9\u05d0\u05e2\u05d1\u05d9\u05e8 \u05d0\u05ea \u05d4\u05db\u05d3\u05d5\u05e8 \u05d1\u05d9\u05df \u05e8\u05d2\u05dc\u05d9 \u05d4\u05e9\u05d5\u05e2\u05e8 (5)",
      "2": "\u05d0\u05dc\u05d9\u05e4\u05d5\u05ea \u05e9\u05dc \u05e2\u05d9\u05e8! (3)",
      "3": "\u05dc\u05d9\u05d9\u05df \u05e9\u05d5\u05d1 \u05d9\u05e9 \u05d8\u05e2\u05dd \u05dc\u05d0 \u05d8\u05d5\u05d1, \u05d1\u05de\u05d9\u05d3\u05d4 \u05de\u05e1\u05d5\u05d9\u05d9\u05de\u05ea (5)",
      "4": "\u05d4\u05d9\u05d0 \u05d4\u05d5\u05dc\u05db\u05ea \u05e9\u05dd \u05dc\u05d1\u05e2\u05d5\u05d8 \u05e4\u05e0\u05d3\u05dc \u05d1\u05d6\u05db\u05d5\u05ea\u05db\u05dd (7)",
      "5": "\u05d4\u05df \u05e8\u05d5\u05d5 \u05d9\u05d9\u05e0\u05d5\u05ea \u05d5\u05e0\u05d9\u05e6\u05d7\u05d5\u05e0\u05d5\u05ea (8) (\u05de)",
      "6": "\u05de\u05d5\u05e9\u05d1 \u05e9\u05d4\u05d5\u05d0 \u05de\u05d5\u05e9\u05d1 \u05d3\u05dc\u05d9\u05dd (4)",
      "7": "\u05d4\u05db\u05d3\u05d5\u05e8\u05d2\u05dc\u05df: \u05d4\u05d0\u05dd \u05d0\u05e9\u05ea\u05d4 \u05d0\u05ea \u05db\u05dc \u05d4\u05d2\u05d1\u05d9\u05e2? (4, 4)",
      "11": "\u05d8\u05d5\u05e8\u05e0\u05d9\u05e8 \u05dc\u05d0\u05d3\u05d5\u05e0\u05d9\u05dd \u05d1\u05dc\u05d1\u05d3? (7)",
      "13": "\u05d5\u05d5\u05e7\u05e8 \u05d5\u05e6'\u05d0\u05e8\u05dc\u05e1 \u05d1\u05ea\u05e8\u05d1\u05d5\u05ea \u05d4\u05e2\u05de\u05de\u05d9\u05ea (7)",
      "15": "\u05db\u05e9\u05d4\u05e0\u05e9\u05d9\u05d0 \u05d4\u05e9\u05dc\u05d9\u05e9\u05d9 \u05d1\u05e4\u05e0\u05d9\u05dd, \u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05d9\u05d5\u05ea \u05e9\u05d4\u05d5\u05d0 \u05d9\u05d1\u05e7\u05d9\u05e2 \u05e9\u05e2\u05e8 (5, 3)",
      "16": "\u05de\u05d1\u05d7\u05d5\u05e5 \u05d4\u05d7\u05dc\u05e4\u05e0\u05d5 \u05de\u05d9\u05df, \u05d5\u05d6\u05d4 \u05d0\u05d5\u05dc\u05d9 \u05ea\u05d2\u05d5\u05d1\u05ea\u05e0\u05d5 \u05db\u05e9\u05e4\u05e1\u05dc\u05d5 \u05dc\u05e0\u05d5 \u05e9\u05e2\u05e8 (8)",
      "17": "\u05e9\u05d5\u05de\u05e8\u05ea \u05de\u05e4\u05e0\u05d9 \u05de\u05d5\u05e2\u05e7\u05ea\u05d9 \u05d4\u05d0\u05d7\u05e8\u05d5\u05e0\u05d4 (7)",
      "19": "\u05ea\u05d2\u05d9\u05d3\u05d5, \u05e8\u05d0\u05e1\u05d9\u05d4 \u05d6\u05d4 \u05d2\u05dd \u05e1\u05d5\u05d2 \u05e9\u05dc \u05e7\u05e8\u05df? (5)",
      "20": "\u05d1\u05dc\u05dd \u05e9\u05d4\u05e4\u05da \u05d0\u05ea \u05d4\u05e7\u05e8\u05df \u05d1\u05e9\u05d1\u05d9\u05dc \u05dc\u05d4\u05e2\u05dc\u05d5\u05ea \u05dc\u05de\u05e2\u05dc\u05d4 (5)",
      "22": "\u05de\u05d2\u05e8\u05e9 \u05e9\u05d4\u05d7\u05dc\u05d9\u05e3 \u05d0\u05ea \u05de\u05d2\u05d1\u05d9\u05d5 \u05de\u05e7\u05d1\u05dc \u05de\u05e9\u05d4\u05d5 \u05de\u05e7\u05d5\u05d3\u05de\u05d5 (4)",
      "24": "\u05e0\u05d1\u05d3\u05dc \u05de\u05d4\u05e6\u05d3\u05d3\u05d9\u05dd, \u05e4\u05e0\u05d3\u05dc \u05de\u05d4\u05e1\u05d5\u05e3 \u05d5\u05d4\u05ea\u05d5\u05e6\u05d0\u05d4 \u05d7\u05d9\u05d4 (3)"
    },
    "across": {
      "1": "\u05dc\u05de\u05e9\u05dc \u05dc\u05e9\u05d9\u05dd \u05de\u05e1\u05e7\u05e8\u05d4 \u05d1\u05d4\u05d9\u05db\u05dc \u05d4\u05ea\u05d7\u05e8\u05d5\u05ea (6, 5)",
      "8": "\u05d1\u05e7\u05d9\u05e6\u05d5\u05e8, \u05d1\u05d9\u05df \u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd \u05d5\u05e7\u05e8\u05d9\u05ea \u05d0\u05e8\u05d1\u05e2 \u05d4\u05d9\u05d4 \u05e4\u05e2\u05dd \u05de\u05d2\u05e8\u05e9 \u05db\u05d3\u05d5\u05e8\u05d2\u05dc (4)",
      "9": "\u05dc\u05d0 \u05d9\u05e9\u05db\u05d7 \u05d0\u05d5\u05ea\u05dd \u05db\u05e9\u05d4\u05d5\u05d0 \u05e2\u05d5\u05d1\u05e8 \u05e9\u05d5\u05d1 \u05dc\u05d4\u05db\u05e0\u05d9\u05e1 \u05d2\u05d5\u05dc\u05d9\u05dd (4, 5)",
      "10": "\u05d1\u05e0\u05d9 \u05dc\u05dd \u05e8\u05d5\u05e6\u05d4 \u05d1\u05dc\u05d9 \u05e1\u05d5\u05e3 \u05dc\u05d7\u05d6\u05d5\u05e8 \u05dc\u05d4\u05d9\u05d5\u05ea \u05d1\u05df \u05d0\u05d3\u05dd \u05e8\u05d2\u05d9\u05dc (6)",
      "12": "\u05d6\u05d4 \u05e9\u05de\u05db\u05d9\u05df \u05dc\u05d5 \u05d0\u05d5\u05db\u05dc \u05d8\u05d5\u05d1 \u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05d9\u05d5\u05ea \u05e7\u05d5\u05d5\u05df \u05d0\u05d5\u05dc\u05d9 (5)",
      "14": "\u05ea\u05d6\u05e8\u05d5\u05e7 \u05de\u05d8\u05d1\u05e2, \u05d6\u05d5 \u05de\u05e6\u05d5\u05d4 (6)",
      "15": "\u05d4\u05dd \u05e2\u05d5\u05d3 \u05d9\u05d3\u05e2\u05d5 \u05dc\u05de\u05d9 \u05d4\u05d2\u05d5\u05dc (4, 3)",
      "17": "\u05d2\u05d9\u05d2\u05e1 \u05db\u05d1\u05e8 \u05dc\u05d0 \u05d0\u05d9\u05ea\u05e0\u05d5 \u05db\u05db\u05d3\u05d5\u05e8\u05d2\u05dc\u05df \u05d1\u05e1\u05d9\u05d5\u05dd \u05d4\u05de\u05e9\u05d7\u05e7 \u05d1\u05d8\u05dc\u05d5\u05d5\u05d9\u05d6\u05d9\u05d4 (7)",
      "18": "\u05e9\u05d7\u05e7\u05df \u05db\u05d3\u05d5\u05e8\u05d2\u05dc \u05e2\u05dd \u05ea\u05d5 (3, 3)",
      "19": "\u05e1\u05d5\u05d1\u05d1 \u05d0\u05ea \u05d4\u05e9\u05e2\u05e8 \u05e9\u05dc \u05e4\u05e8\u05d9\u05d3\u05de\u05df (5)",
      "21": "\u05de\u05d4 \u05e9\u05d9\u05e9 \u05d1\u05e8\u05d7\u05d5\u05d1\u05d5\u05ea \u05d4\u05e0\u05de\u05e6\u05d0\u05d9\u05dd \u05de\u05e9\u05e0\u05d9 \u05e6\u05d9\u05d3\u05d9 \u05d4\u05de\u05d2\u05e8\u05e9 (6)",
      "23": "\u05e9\u05de\u05d7\u05d4 \u05dc\u05e8\u05d2\u05dc \u05d7\u05d5\u05e7\u05d9\u05d5 \u05e9\u05dc \u05d4\u05d1\u05e8\u05d6\u05d9\u05dc\u05d0\u05d9 (9)",
      "25": "\u05de\u05d0\u05de\u05df \u05db\u05d3\u05d5\u05e8\u05d2\u05dc \u05d5\u05d2\u05dd \u05d1\u05e2\u05dc \u05de\u05e7\u05e6\u05d5\u05e2 (4)",
      "26": "\u05d4\u05d5\u05d0 \u05d4\u05e8\u05e9\u05d9\u05ea \u05d2\u05d5\u05dc \u05dc\u05e9\u05dd, \u05d5\u05d6\u05d4 \u05e7\u05d5\u05e8\u05d4 \u05db\u05de\u05d4 \u05e4\u05e2\u05de\u05d9\u05dd \u05d1\u05db\u05dc \u05e9\u05e0\u05d4 (5, 6)"
