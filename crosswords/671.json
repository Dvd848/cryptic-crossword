  "definitions": {
    "down": {
      "1": "\u05e8\u05d0\u05d4/\u05d9 2 \u05de\u05d0\u05d5\u05e0\u05da",
      "2": "\u05e2\u05dd 1 \u05de\u05d0\u05d5\u05e0\u05da. \u05dc\u05d0 \u05d4\u05d0\u05de\u05d9\u05df \u05d0\u05e4\u05d9\u05dc\u05d5 \u05e9\u05d7\u05d5\u05d5\u05d4 \u05d1\u05d7\u05d5\u05e9 \u05d1\u05e9\u05e8\u05d5\u05df (3, 5) (\u05de)",
      "3": "\u05e2\u05d1\u05e8 \u05e2\u05dc \u05d4\u05e6\u05d5\u05de\u05ea, \u05d6\u05d4 \u05e7\u05d9\u05e6\u05d5\u05e0\u05d9! (5)",
      "4": "\u05e8\u05d5\u05e6\u05d9\u05dd \u05dc\u05e7\u05d1\u05d5\u05e2 \u05dc\u05d1\u05d3 \u05d5\u05e9\u05d5\u05d1 \u05de\u05d7\u05e4\u05e9\u05d9\u05dd \u05dc\u05da \u05de\u05d3\u05e8\u05d9\u05db\u05d9\u05dd (7)",
      "5": "\u05de\u05e9\u05d4\u05d5 \u05d1\u05d6\u05e8\u05ea \u05d9\u05db\u05d5\u05dc \u05dc\u05d4\u05d9\u05d5\u05ea \u05de\u05d0\u05d3 \u05de\u05d1\u05dc\u05d1\u05dc (4, 4)",
      "6": "\u05e7\u05d9\u05d1\u05d5\u05e5 \u05db\u05de\u05d5 \u05d1\u05e8\u05d5\u05e8 (4)",
      "7": "\u05d6\u05d5\u05e8\u05e7\u05d9\u05dd \u05d0\u05d5\u05ea\u05d5 \u05db\u05de\u05d5 \u05ea\u05e7\u05d5\u05e4\u05d4 \u05d9\u05ea\u05d5\u05de\u05d4 (4, 4)",
      "11": "\u05d8\u05d9\u05dc \u05e9\u05d0\u05e4\u05e9\u05e8 \u05dc\u05d4\u05e9\u05d9\u05d2 \u05d1\u05d0\u05d7\u05d5\u05d6 \u05d0\u05d5 \u05d7\u05e6\u05d9 \u05d0\u05d7\u05d5\u05d6 \u05de\u05d4\u05de\u05d7\u05d9\u05e8 (7) (\u05d7)",
      "13": "\u05d6\u05d4 \u05e9\u05d0\u05e0\u05d9 \u05db\u05d5\u05ea\u05d1 \u05d1\u05d5 \u05e2\u05dc \u05dc\u05d5\u05d7 \u05de\u05e6\u05e4\u05d5\u05df \u05d0\u05d9\u05e8\u05d5\u05e4\u05d4, \u05d1\u05d0\u05e8\u05e5 \u05d0\u05d9\u05df \u05d4\u05e8\u05d1\u05d4 \u05db\u05d0\u05dc\u05d4 (3, 4)",
      "15": "\u05e9\u05d5\u05d1 \u05de\u05ea\u05e0\u05d4 \u05ea\u05e9\u05e8\u05e3? \u05e9\u05dc\u05d9\u05dc\u05d9, \u05d4\u05d5\u05d0 \u05d9\u05e6\u05d0 \u05dc\u05d7\u05d5\u05e4\u05e9\u05d9 (3, 5)",
      "16": "\u05e9\u05d7\u05e7\u05df \u05e2\u05d1\u05e8 \u05e9\u05e0\u05d4\u05e8 \u05dc\u05e4\u05e0\u05d9 \u05d4\u05d7\u05d3\u05e8 \u05e9\u05dc\u05d5 (4, 4) (\u05d7)",
      "17": "\u05d3\u05d2 \u05e9\u05d7\u05d5\u05d6\u05e8 \u05d5\u05d9\u05e9 \u05dc\u05d5 \u05e9\u05e0\u05d9 \u05d4\u05d5\u05e8\u05d9\u05dd (7)",
      "19": "\u05d3\u05d1\u05e9 \u05d1\u05e9\u05d1\u05d9\u05dc\u05d9 \u05d6\u05d4 \u05e9\u05d1\u05d8 (5)",
      "20": "\u05d3\u05d2 \u05d1\u05dc\u05d7\u05dd? \u05d6\u05d4 \u05d6\u05d1\u05dc (5)",
      "22": "\u05d9\u05dc\u05d3\u05d4 \u05d1\u05dc\u05e2\u05d4 \u05de\u05e0\u05d5\u05d7 \u05d1\u05e6\u05d1\u05e2 \u05e9\u05d7\u05d5\u05e8 (4)",
      "24": "\u05d4\u05d5\u05d0 \u05d4\u05e9\u05de\u05d9\u05e2 \u05d0\u05ea \u05e7\u05d5\u05dc\u05d5 \u05d1\u05d9\u05df \u05e9\u05ea\u05d9\u05dd \u05dc\u05d0\u05e8\u05d1\u05e2 \u05e4\u05e2\u05de\u05d9\u05d9\u05dd? \u05dc\u05d4\u05d9\u05e4\u05da! (3)"
    },
    "across": {
      "1": "\u05ea\u05d1\u05dc\u05d9\u05df \u05dc\u05d0 \u05e7\u05dc \u05d5\u05dc\u05d0 \u05e7\u05e9\u05d4? \u05e7\u05d7 \u05e2\u05e6\u05d4 \u05de\u05de\u05d9 \u05e9\u05dc\u05d0 \u05e4\u05e0\u05d4 \u05dc\u05e9\u05d1\u05d9\u05dc\u05d9\u05dd \u05e6\u05d3\u05d3\u05d9\u05d9\u05dd (3, 4, 4)",
      "8": "\u05db\u05d5\u05dc\u05dc \u05e9\u05d3 \u05d0\u05d1\u05dc \u05d0\u05e3 \u05d0\u05d7\u05d3 \u05d0\u05d7\u05e8 \u05dc\u05d0 (4)",
      "9": "\u05de\u05d7\u05e1\u05d5\u05e8 \u05de\u05e2\u05d5\u05e8\u05d1 \u05d1\u05e4\u05e8\u05e9\u05d4, \u05d6\u05d4 \u05d6\u05d3\u05d5\u05e0\u05d9! (5, 4)",
      "10": "\u05de\u05d7\u05d6\u05d4 \u05e9\u05d1\u05e1\u05d5\u05e3 \u05de\u05e9\u05d1\u05d9\u05d6? \u05d1\u05e8\u05d5\u05e8 (6)",
      "12": "\u05e4\u05d2\u05d9\u05e9\u05d4 \u05e2\u05dd \u05dc\u05d0 \u05d9\u05d4\u05d5\u05d3\u05d9 \u05db\u05d3\u05d9 \u05dc\u05e7\u05d1\u05d5\u05e2 \u05db\u05d9\u05d5\u05d5\u05df (5)",
      "14": "\u05d9\u05e0\u05e1\u05d5 \u05dc\u05d4\u05d1\u05d9\u05df \u05dc\u05e4\u05e0\u05d9 \u05d4\u05ea\u05dc\u05de\u05d9\u05d3\u05d9\u05dd \u05d5\u05d6\u05d4 \u05d9\u05d4\u05d9\u05d4 \u05dc\u05d5 \u05db\u05d9\u05e3 (6)",
      "15": "\u05d0\u05e1\u05e4\u05d5 \u05e9\u05df \u05e9\u05dc \u05d1\u05e2\u05dc \u05de\u05e7\u05e6\u05d5\u05e2 (7)",
      "17": "\u05ea\u05e2\u05dc\u05d9\u05dd \u05d1\u05e9\u05dc\u05d9\u05dc\u05d4 \u05d0\u05ea \u05d4\u05de\u05e0\u05d5\u05d5\u05dc\u05ea (2, 5)",
      "18": "\u05ea\u05d5\u05d0\u05e8 \u05e9\u05dc \u05ea\u05dc\u05d5\u05e0\u05d4 \u05db\u05e4\u05d5\u05dc\u05d4 (6)",
      "19": "\u05e0\u05e1\u05d7\u05d1 \u05d0\u05dc\u05d9\u05e0\u05d5 \u05db\u05d9 \u05d4\u05d5\u05d0 \u05de\u05ea\u05d2\u05d5\u05e8\u05e8 \u05d1\u05e6\u05de\u05e8\u05ea (5)",
      "21": "\u05d4\u05de\u05d5\u05e8\u05d4 \u05e9\u05dc\u05d9 \u05e9\u05d5\u05d7\u05d4 \u05d1\u05e7\u05d9\u05d1\u05d5\u05e5 (6)",
      "23": "\u05ea\u05dc\u05de\u05d9\u05d3 \u05d7\u05db\u05dd \u05e0\u05e9\u05d0\u05e8? \u05d4\u05d5\u05d0 \u05dc\u05d0 \u05e6\u05e8\u05d9\u05da \u05d9\u05d5\u05ea\u05e8 \u05db\u05d9 \u05dc\u05d4\u05df \u05d9\u05e9 \u05ea\u05d3\u05e8\u05d9\u05dd (5, 4)",
      "25": "\u05d4\u05d9\u05dc\u05d3 \u05e9\u05dc \u05d0\u05e8\u05d6 \u05d1\u05d2\u05d5\u05dc\u05df (4)",
      "26": "\u05e0\u05d7\u05dc\u05e9\u05d5 \u05dc\u05e4\u05e0\u05d9 \u05d4\u05d4\u05ea\u05d7\u05dc\u05d4 \u05d5\u05e9\u05d9\u05e0\u05d4 \u05de\u05e7\u05d5\u05dd \u05de\u05d2\u05d5\u05e8\u05d9\u05dd, \u05d6\u05d4 \u05d4\u05e8\u05d5\u05d5\u05d7 \u05d4\u05db\u05d9 \u05d2\u05d3\u05d5\u05dc (5, 6) (\u05de)"
