      "11": "\u05dc\u05d0 \u05de\u05e7\u05d1\u05dc\u05d9\u05dd \u05de\u05d7\u05d9\u05d5\u05ea (7)",
      "13": "\u05d1\u05d0\u05d9\u05d6\u05d5 \u05e2\u05d9\u05e8 \u05e9\u05d5\u05d1 \u05d4\u05de\u05d8\u05d1\u05e2 \u05d9\u05d5\u05e7\u05e3 \u05d1\u05e9\u05d1\u05d7\u05d9\u05dd? (7)",
