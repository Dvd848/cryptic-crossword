      "21": "\u05dc\u05d0 \u05d4\u05e6\u05dc\u05d9\u05d7 \u05dc\u05d4\u05db\u05d9\u05dc \u05d8\u05d5\u05d1 \u05e2\u05d5\u05de\u05d3 \u05d1\u05d1\u05d9\u05e8\u05d4 (6)",
      "23": "\u05e6\u05d5\u05de\u05ea \u05de\u05e8\u05db\u05d6, \u05e9\u05e0\u05d9 \u05de\u05e1\u05dc\u05d5\u05dc \u05d1\u05e9\u05d1\u05d9\u05dc\u05d9, \u05dc\u05d0 \u05db\u05d3\u05d0\u05d9 \u05dc\u05d4\u05d9\u05d5\u05ea \u05d1\u05de\u05e1\u05dc\u05d5\u05dc \u05e9\u05dc\u05d5 (3, 6)",
      "25": "\u05e2\u05e0\u05e3 \u05db\u05dc\u05db\u05dc\u05d9 \u05d0\u05d5 \u05d4\u05d6\u05de\u05e0\u05d4 \u05dc\u05d4\u05db\u05e0\u05e1 (4)",
