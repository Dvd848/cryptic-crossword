  "definitions": {
    "down": {
      "1": "\u05db\u05d1\u05e8 \u05dc\u05d0 \u05de\u05e2\u05da \u05e6\u05d3 (5)",
      "2": "\u05e8\u05d0\u05d4/\u05d9 3 \u05de\u05d0\u05d5\u05e0\u05da",
      "3": "\u05e2\u05dd 2 \u05de\u05d0\u05d5\u05e0\u05da. \u05d0\u05dc \u05ea\u05ea\u05df \u05dc\u05de\u05e7\u05d5\u05dd \u05d4\u05d4\u05de\u05ea\u05e0\u05d4 \u05dc\u05e2\u05de\u05d5\u05d3 \u05d1\u05ea\u05d7\u05d9\u05dc\u05ea \u05e1\u05e4\u05e8 \u05e9\u05de\u05d5\u05d0\u05dc (5, 3) (\u05de)",
      "4": "\u05d0\u05d9\u05d6\u05d4 \u05e9\u05d7\u05e7\u05df \u05e9\u05d5\u05d1 \u05d9\u05d7\u05d6\u05d4 \u05d4\u05e8\u05d2 (3, 4)",
      "5": "\u05e8\u05d0\u05d4/\u05d9 8 \u05de\u05d0\u05d5\u05d6\u05df",
      "6": "\u05d0\u05d7\u05ea \u05de\u05d0\u05e8\u05d1\u05e2 \u05d1\u05de\u05d8\u05d1\u05e2, \u05d9\u05d4\u05d9\u05d4 \u05d0\u05d7\u05e8\u05d0\u05d9 \u05e2\u05dc \u05e7\u05d1\u05d5\u05e6\u05d4 (4)",
      "7": "\u05d1\u05d5\u05e8 \u05e9\u05d7\u05e1\u05e8 \u05d1\u05d5 \u05de\u05d8\u05d1\u05e2 \u05d1\u05d8\u05dc\u05d5\u05d9\u05d6\u05d9\u05d4 \u05e4\u05e2\u05dd (3, 5)",
      "11": "\u05e7\u05dc\u05dc \u05de\u05d7\u05d6\u05d0\u05d9 \u05d1\u05e0\u05d5\u05d6\u05dc \u05db\u05d3\u05d9 \u05dc\u05d5\u05d5\u05d3\u05d0 \u05e9\u05d6\u05d4 \u05d9\u05d2\u05d9\u05e2 (3, 4) (\u05d7)",
      "13": "\u05d1\u05e9\u05dc \u05d5\u05d1\u05d0\u05de\u05e6\u05e2 \u05d4\u05dd \u05e2\u05d1\u05d3\u05d5 \u05db\u05d3\u05d9 \u05dc\u05d4\u05e4\u05e2\u05d9\u05dc \u05de\u05db\u05e9\u05d9\u05e8 \u05d7\u05e9\u05de\u05dc\u05d9 (3, 4)",
      "15": "\u05d0\u05e2\u05de\u05d9\u05d3 \u05d1\u05e4\u05e0\u05d9\u05dd \u05d7\"\u05db \u05d1\u05e9\u05d1\u05d9\u05dc \u05d1\u05e2\u05dc\u05d9 \u05d4\u05d9\u05d5\u05d6\u05de\u05d4 (8)",
      "16": "\u05d4\u05e8\u05e2\u05d9\u05d3\u05d5\u05ea \u05d6\u05d6\u05d5 \u05d5\u05e6\u05d9\u05d9\u05e8\u05d5 \u05d0\u05d5\u05ea\u05dd (8)",
      "17": "\u05e2\u05d3\u05d9\u05e3 \u05d1\u05e9\u05d1\u05d9\u05dc\u05e0\u05d5 \u05de\u05e7\u05dc, \u05dc\u05d0 \u05d3\u05d5\u05e7\u05d8\u05d5\u05e8 (4, 3)",
      "19": "\u05d0\u05e0\u05d9 \u05e0\u05e9\u05d5\u05d0\u05d4 \u05dc\u05dc\u05d5\u05d9 \u05dc\u05de\u05e9\u05dc, \u05d1\u05d1\u05e8\u05d5\u05e8 (5)",
      "20": "\u05dc\u05d4\u05d6\u05db\u05d9\u05e8 \u05de\u05e6\u05d7\u05d9\u05e7 \u05d5\u05de\u05e9\u05e7\u05d4 (5)",
      "22": "\u05e9\u05d5\u05d1 \u05d4\u05d5\u05d0 \u05d9\u05d0\u05de\u05e8 \u05e9\u05d0\u05e4\u05e9\u05e8 \u05d0\u05d6 \u05d4\u05d5\u05d0 \u05d9\u05db\u05d5\u05dc (4)",
      "24": "\u05de\u05d3\u05d9\u05e0\u05d4 \u05e9\u05de\u05d7\u05d6\u05d9\u05e8\u05d4 \u05e2\u05d9\u05e8 (3)"
    },
    "across": {
      "1": "\u05dc\u05e7\u05e8\u05d5\u05d1\u05d4 \u05d9\u05e9 \u05de\u05e4\u05e1\u05e7 \u05d5\u05ea\u05d5 \u05d5\u05e9\u05d9\u05e7\u05d5\u05dc \u05d3\u05e2\u05ea \u05d0\u05de\u05d9\u05ea\u05d9 (2, 5, 4)",
      "8": "\u05e2\u05dd 5 \u05de\u05d0\u05d5\u05e0\u05da. \u05e1\u05e4\u05e8 \u05d1\u05de\u05e7\u05e8\u05d4 \u05e9\u05d9\u05e7\u05d7 \u05d1\u05d4\u05e9\u05d0\u05dc\u05d4 \u05d2'\u05de\u05d5\u05e1 (4, 8)",
      "9": "\u05d4\u05db\u05d9\u05df \u05d1\u05ea\u05d5\u05db\u05d9 \u05d7\u05d5\u05de\u05e9 \u05d5\u05d4\u05e8\u05e1 \u05d0\u05d5\u05ea\u05d9 (3, 2, 4)",
      "10": "\u05de\u05d3\u05d3 \u05e6\u05e8 \u05dc\u05d0 \u05e7\u05d9\u05d9\u05dd \u05de\u05e9\u05d5\u05dd \u05e6\u05d3 (6)",
      "12": "\u05e7\u05d5\u05d3\u05dd \u05db\u05dc \u05d0\u05dc \u05ea\u05dc\u05da \u05e9\u05d5\u05d1 (5)",
      "14": "\u05d3\u05d5\u05d2\u05de\u05df \u05e9\u05dc\u05d0 \u05e0\u05e9\u05d0\u05e8 \u05d1\u05e2\u05de\u05d5\u05d3\u05d4 (3, 3) (\u05d7)",
      "15": "\u05e0\u05d0\u05e6\u05d9 \u05d9\u05de\"\u05e9 (7)",
      "17": "\u05de\u05d6\u05e8\u05d6 \u05d7\u05d3\u05dc\u05d5\u05df \u05de\u05d1\u05d7\u05d5\u05e5 \u05db\u05de\u05d5 \u05e9\u05d4\u05df \u05e2\u05d5\u05d6\u05e8\u05d5\u05ea \u05dc\u05d4\u05d1\u05d9\u05df (7)",
      "18": "\u05d4\u05d5\u05d0 \u05dc\u05d0 \u05d4\u05d9\u05d4 \u05d0\u05de\u05d9\u05df \u05d5\u05d4\u05e8\u05d2\u05d9\u05e9 \u05d1\u05d8\u05d5\u05e8\u05e3 \u05e9\u05dc\u05d5 (4, 2)",
