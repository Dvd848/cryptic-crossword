    },
    "across": {
      "1": "\u05d7\u05d5\u05e7\u05e8 \u05de\u05e0\u05d4\u05d9\u05d2 \u05e9\u05d9\u05e9 \u05dc\u05d0\u05e8\u05d2\u05e0\u05d5 \u05e2\u05dd \u05e0\u05d9\u05e6\u05d7\u05d5\u05df \u05d0\u05e0\u05d2\u05dc\u05d9 (5, 6) (\u05de)",
