  "definitions": {
    "down": {
      "1": "\u05d4\u05e8\u05db\u05d1 \u05db\u05d1\u05e8 \u05e4\u05d4, \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd (2, 3)",
      "2": "\u05e2\u05dd 15 \u05de\u05d0\u05d5\u05e0\u05da. \u05d4\u05d2\u05d9\u05d1\u05d5\u05e8, \u05d4\u05e2\u05d9\u05e8, \u05d4\u05d9\u05d5 \u05e9\u05d5\u05d1 \u05d1\u05e2\u05d9\u05e8 \u05d4\u05e2\u05ea\u05d9\u05e7\u05d4 (3, 8)",
      "3": "\u05dc\u05d0 \u05d4\u05d5\u05dc\u05da \u05dc\u05d9\u05e9\u05d5\u05df \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd, \u05d2\u05dd \u05d4\u05dd \u05d2\u05e8\u05d9\u05dd \u05e9\u05dd (5)",
      "4": "\u05e2\u05dd 8 \u05de\u05d0\u05d5\u05d6\u05df. \u05e2\"\u05e4 \u05d4\u05e9\u05d9\u05e8 \u05d7\u05d6\u05e8\u05e0\u05d5 \u05db\u05e9\u05d4\u05e2\u05d5\u05e3 \u05e9\u05d5\u05d1 \u05d7\u05d5\u05d3\u05e8 \u05dc\u05d0\u05d5\u05e1\u05e4\u05d9\u05dd (2, 5, 4)",
      "5": "\u05d4\u05d1\u05d9\u05e8\u05d4 \u05e7\u05dc\u05d4 \u05de\u05d4\u05dd \u05d1\u05db\u05d5\u05e8 \u05d4\u05d2\u05e8\u05e2\u05d9\u05e0\u05d9 (3, 5)",
      "6": "\u05d4\u05d3\u05d5\u05e7\u05d8\u05d5\u05e8 \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd \u05d1\u05d0\u05de\u05e6\u05e2, \u05de\u05e1\u05d1\u05d9\u05d1 \u05d4\u05e1\u05e2\u05e8 (4)",
      "7": "\u05d4\u05e7\u05e6\u05d9\u05df \u05e9\u05dc\u05d5 \u05d1\u05d7\u05d9\u05d9\u05dd \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd (4, 4)",
      "11": "\u05dc\u05d4\u05d9\u05d5\u05ea \u05d1\u05e9\u05d1\u05d9\u05dc\u05d4 \u05d1\u05df \u05e9\u05d0\u05db\u05dc \u05d0\u05ea \u05d3\u05e0\u05d9 (7) (\u05de)",
      "13": "\u05d1\u05d0\u05d9\u05d6\u05d4 \u05d0\u05e8\u05d2\u05d5\u05df \u05d4\u05d9\u05dc\u05d3 \u05e9\u05dc\u05d9 \u05de\u05ea\u05e7\u05e9\u05d4 \u05dc\u05d4\u05ea\u05e4\u05e8\u05e0\u05e1 \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd (2, 5)",
      "15": "\u05e8\u05d0\u05d4/\u05d9 2 \u05de\u05d0\u05d5\u05e0\u05da",
      "16": "\u05d0\u05d9\u05df \u05e2\u05e7\u05e9\u05df \u05db\u05de\u05d5\u05d4\u05d5, \u05d0\u05d1\u05e9\u05dc\u05d5\u05dd (4, 4)",
      "17": "\u05dc\u05de\u05e9\u05dc \u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd, \u05e4\u05ea\u05d7 \u05ea\u05e7\u05d5\u05d4, \u05dc\u05d0 \u05d7\u05d5\u05d6\u05e8\u05d5\u05ea, \u05e9\u05d1 \u05d1\u05e9\u05e7\u05d8! (2, 5)",
      "19": "\u05d4\u05e9\u05d5\u05e4\u05d8 \u05e1\u05e4\u05d2 \u05e9\u05d5\u05d1 \u05d7\u05e6\u05d9 \u05de\u05d8\u05e8\u05d3 \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd (5)",
      "20": "\u05dc\u05d0 \u05d0\u05de\u05e8\u05ea\u05d9 \u05db\u05dc\u05d5\u05dd \u05d1\u05ea\u05d2\u05d5\u05d1\u05d4 \u05dc\u05ea\u05d7\u05d9\u05d9\u05ea \u05d4\u05de\u05ea\u05d9\u05dd \u05d4\u05e4\u05e8\u05d8\u05d9\u05ea \u05e9\u05dc\u05d9 (5)",
      "22": "\u05e9\u05d5\u05d1 \u05e2\u05d5\u05dc\u05d4 \u05d4\u05de\u05e0\u05d2\u05d9\u05e0\u05d4 \u05d5\u05d4\u05d9\u05d0 \u05d7\u05dc\u05e7\u05d4 (4)",
      "24": "\u05db\u05d5\u05d7 \u05e9\u05dc\u05d9\u05e9\u05d9 (3)"
    },
    "across": {
      "1": "\u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd \u05d4\u05de\u05d8\u05d1\u05e2 \u05e0\u05d5\u05ea\u05df \u05dc\u05d4 \u05dc\u05d4\u05e1\u05ea\u05db\u05dc \u05d0\u05d7\u05d5\u05e8\u05d4 (5, 6)",
      "8": "\u05e8\u05d0\u05d4/\u05d9 4 \u05de\u05d0\u05d5\u05e0\u05da",
      "9": "\u05d4\u05d0\u05d1\u05d9\u05d5\u05df \u05d4\u05ea\u05d1\u05dc\u05d1\u05dc \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd \u05d0\u05d5 \u05d1\u05ea\u05dc \u05d0\u05d1\u05d9\u05d1? (3, 6)",
      "10": "\u05d1\u05d7\u05d9\u05e4\u05d4 \u05d1\u05e0\u05d5 \u05db\u05ea\u05e8 \u05dc\u05d9-\u05dd (6)",
      "12": "\u05ea\u05de\u05d5\u05e0\u05d9\u05ea \u05d4\u05d9\u05d0 \u05dc\u05de\u05e9\u05dc \u05ea\u05d0\u05e0\u05d4 \u05ea\u05d5\u05e6\u05e8\u05ea \u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd (5)",
      "14": "\u05e2\u05d5\u05d1\u05d3\u05ea\u05d9 \u05e9\u05d6\u05d4 \u05e7\u05d9\u05d9\u05dd \u05db\u05de\u05e2\u05d8 \u05d1\u05db\u05dc \u05d1\u05e0\u05d9\u05d9\u05df \u05de\u05d2\u05d5\u05e8\u05d9\u05dd (3, 3)",
      "15": "\u05d4\u05d1\u05d9\u05d0\u05d5 \u05d1\u05e2\u05dc \u05d7\u05d9\u05d9\u05dd \u05dc\u05e9\u05db\u05d5\u05e0\u05d4 \u05d1\u05d4\u05e8 \u05d4\u05e8\u05e6\u05dc \u05d1\u05d9\u05d5\u05dd \u05d4\u05e2\u05e6\u05de\u05d0\u05d5\u05ea (7)",
      "17": "\u05d0\u05e0\u05d9 \u05de\u05e1\u05ea\u05db\u05dc \u05d1\u05db\u05d7 \u05d1\u05d7\u05d3\u05e8 \u05d4\u05e8\u05d7\u05e6\u05d4 (7)",
      "18": "\u05e0\u05d8\u05dc\u05d5 \u05de\u05dc\u05d5\u05df (\u05e9\u05d9\u05e9 \u05d2\u05dd \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd) (6)",
      "19": "\u05d4\u05e9\u05d5\u05e4\u05d8 \u05e1\u05e4\u05d2 \u05e9\u05d5\u05d1 \u05d7\u05e6\u05d9 \u05de\u05d8\u05e8\u05d3 \u05d1\u05d9\u05e8\u05d5\u05e9\u05dc\u05d9\u05dd (5)",
      "21": "\u05e9\u05d5\u05e9\u05dc\u05ea \u05d8\u05e8\u05d5\u05dd \u05e0\u05d5\u05d1\u05de\u05d1\u05e8 (6)",
      "23": "\u05d1\u05e8\u05d0\u05e9\u05d5 \u05e9\u05dc \u05d4\u05d2\u05d1\u05d5\u05d4 \u05dc\u05d0 \u05e7\u05e8 \u05db\u05d9 \u05d4\u05d5\u05d0 \u05e1\u05ea\u05d5\u05dd (3, 6)",
      "25": "\u05d4\u05d5\u05d0 \u05e9\u05d5\u05d1 \u05d0\u05d9\u05e0\u05d5 \u05de\u05ea\u05d9\u05d9\u05d7\u05e1 \u05d1\u05db\u05d1\u05d5\u05d3 \u05dc\u05de\u05e7\u05d3\u05e9 (4)",
